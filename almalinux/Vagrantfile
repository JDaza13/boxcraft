# ============================================================
#  AlmaLinux 9 Headless Box - Vagrantfile
#  Hypervisor : VirtualBox  |  Access : vagrant ssh (no GUI)
#  Tools      : git, gh CLI, Docker, nvm/Node LTS,
#               Go, Rust, Python 3, vim, tmux, zsh
#
#  Usage:
#    vagrant up          # first boot (~2 min with baked image)
#    vagrant ssh         # open a shell
#    vagrant halt        # graceful shutdown
#    vagrant destroy -f  # wipe everything
# ============================================================

load File.join(__dir__, '..', 'vm.rb')

dev_user, dev_password = prompt_dev_credentials(__dir__)
dev_tz = VM_TZ_DEFAULT
box    = baked_box(__dir__, baked: "boxcraft/almalinux", upstream: "bento/almalinux-9")

Vagrant.configure("2") do |config|
  stale_vm_cleanup(config, "#{dev_user}-almalinux", __dir__)

  config.vm.box              = box
  config.vm.box_check_update = false
  config.vm.hostname         = "#{dev_user}-almalinux"

  # ── NAT port forwarding ────────────────────────────────────
  config.vm.network "forwarded_port", guest: 8080, host: 8080, id: "http-alt"
  config.vm.network "forwarded_port", guest: 3000, host: 3000, host_ip: "0.0.0.0", id: "node"
  config.vm.network "forwarded_port", guest: 5173, host: 5173, host_ip: "0.0.0.0", id: "vite"
  config.vm.network "forwarded_port", guest: 5174, host: 5174, host_ip: "0.0.0.0", id: "vite2"
  config.vm.network "forwarded_port", guest: 8000, host: 8000, host_ip: "0.0.0.0", id: "python"

  # ── Shared folders ─────────────────────────────────────────
  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.synced_folder VM_WORKSPACE, "/workspace",
    owner:         "vagrant",
    group:         "vagrant",
    mount_options: ["dmode=775", "fmode=664", "_netdev"]

  # ── VirtualBox provider ────────────────────────────────────
  # Defaults to 4 GB / 2 CPUs — lighter than the desktop profiles.
  # Override with $env:VM_RAM_MB and $env:VM_CPUS before vagrant up.
  config.vm.provider "virtualbox" do |vb|
    vb.name   = "#{dev_user}-almalinux"
    vb.memory = ENV.fetch('VM_RAM_MB', '4096').to_i
    vb.cpus   = ENV.fetch('VM_CPUS',   '2').to_i
    vb.gui    = false

    vb.customize ["modifyvm", :id, "--paravirtprovider", "kvm"]
    vb.customize ["modifyvm", :id, "--x2apic",           "on"]
    vb.customize ["modifyvm", :id, "--largepages",        "on"]
  end

  standard_provisioners(config,
    profile_dir:  __dir__,
    dev_user:     dev_user,
    dev_password: dev_password,
    dev_tz:       dev_tz
  )

end
