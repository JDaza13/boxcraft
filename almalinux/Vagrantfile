# ============================================================
#  AlmaLinux 9 Headless Box — Vagrantfile
#  Hypervisor : VirtualBox
#  Access     : vagrant ssh (no GUI)
#  Tools      : git, gh CLI, Docker, nvm/Node LTS,
#               Go, Rust, Python 3, vim, tmux, zsh
#
#  Usage:
#    vagrant up       # first boot (~2 min with baked image)
#    vagrant ssh      # open a shell
#    vagrant halt     # shut down
#    vagrant destroy -f
#    vagrant provision --provision-with tune
# ============================================================

load File.join(__dir__, '..', 'vm.rb')
require 'io/console'
vm_id_file   = File.join(__dir__, '.vagrant', 'machines', 'default', 'virtualbox', 'id')
user_file    = File.join(__dir__, '.vagrant', 'dev_user')
dev_user     = ENV['DEV_USER']
dev_password = ENV['DEV_PASSWORD']

if ARGV.first == 'up' && !IS_PACKER_BUILD && (!File.exist?(vm_id_file) || File.read(vm_id_file).strip.empty?)
  $stdout.print "\n>>> Username for dev user [dev]: "
  $stdout.flush
  input = $stdin.gets.chomp
  dev_user = input.empty? ? "dev" : input

  $stdout.print ">>> Set password for '#{dev_user}': "
  $stdout.flush
  dev_password = $stdin.noecho(&:gets).chomp
  puts ""

  File.write(user_file, dev_user)
end

dev_user     ||= File.exist?(user_file) ? File.read(user_file).strip : "dev"
dev_password ||= ""
dev_tz         = VM_TZ_DEFAULT

PACKER_BUILT = File.join(__dir__, '.vagrant', 'packer_built')
USE_BAKED    = File.exist?(PACKER_BUILT)
BOX          = USE_BAKED ? "boxcraft/almalinux" : "bento/almalinux-9"

Vagrant.configure("2") do |config|

  config.vm.box              = BOX
  config.vm.box_check_update = false
  config.vm.hostname         = "#{dev_user}-almalinux"

  # ── NAT port forwarding ────────────────────────────────────
  config.vm.network "forwarded_port", guest: 8080, host: 8080, id: "http-alt"
  config.vm.network "forwarded_port", guest: 3000, host: 3000, host_ip: "0.0.0.0", id: "node"
  config.vm.network "forwarded_port", guest: 5173, host: 5173, host_ip: "0.0.0.0", id: "vite"
  config.vm.network "forwarded_port", guest: 5174, host: 5174, host_ip: "0.0.0.0", id: "vite2"
  config.vm.network "forwarded_port", guest: 8000, host: 8000, host_ip: "0.0.0.0", id: "python"

  # ── Shared folders ─────────────────────────────────────────
  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.synced_folder VM_WORKSPACE, "/workspace",
    owner:         "vagrant",
    group:         "vagrant",
    mount_options: ["dmode=775", "fmode=664", "_netdev"]

  # ── VirtualBox provider ────────────────────────────────────
  config.vm.provider "virtualbox" do |vb|
    vb.name   = "#{dev_user}-almalinux"
    vb.memory = ENV.fetch('VM_RAM_MB', '4096').to_i
    vb.cpus   = ENV.fetch('VM_CPUS',   '2').to_i
    vb.gui    = false

    vb.customize ["modifyvm", :id, "--paravirtprovider", "kvm"]
    vb.customize ["modifyvm", :id, "--x2apic",           "on"]
    vb.customize ["modifyvm", :id, "--largepages",        "on"]
  end

  # ── Provisioning ───────────────────────────────────────────
  unless USE_BAKED
    config.vm.provision "file",
      source:      "provision-base.sh",
      destination: "/tmp/provision-base.sh"

    config.vm.provision "shell", name: "system", privileged: true,
      run:    "once",
      inline: "bash /tmp/provision-base.sh"
  end

  config.vm.provision "file",
    source:      "provision.sh",
    destination: "/tmp/provision.sh"

  config.vm.provision "shell", name: "base", privileged: true,
    run:    "once",
    reboot: true,
    env:    { "DEV_USER" => dev_user, "DEV_PASSWORD" => dev_password, "DEV_TZ" => dev_tz },
    inline: "bash /tmp/provision.sh"

  config.vm.provision "file",
    source:      "provision-tune.sh",
    destination: "/tmp/provision-tune.sh",
    run:         "always"

  config.vm.provision "shell", name: "tune", privileged: true,
    run:    "always",
    env:    { "DEV_USER" => dev_user },
    inline: "bash /tmp/provision-tune.sh"

end
