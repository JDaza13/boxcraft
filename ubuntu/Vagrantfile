# ============================================================
#  Ubuntu 24.04 Desktop Workstation - Vagrantfile
#  Hypervisor : VirtualBox  |  Desktop : GNOME
#  Tools      : git, gh CLI, Docker, nvm/Node LTS,
#               tmux, zsh, oh-my-zsh, Go, Rust, VS Code
#
#  Usage:
#    vagrant up          # first boot (~2 min with baked image)
#    vagrant reload      # reboot VM
#    vagrant ssh         # terminal access
#    vagrant halt        # graceful shutdown
#    vagrant destroy -f  # wipe everything
# ============================================================

load File.join(__dir__, '..', 'vm.rb')

dev_user, dev_password = prompt_dev_credentials(__dir__)
dev_tz = VM_TZ_DEFAULT
box    = baked_box(__dir__, baked: "boxcraft/ubuntu", upstream: "bento/ubuntu-24.04")

Vagrant.configure("2") do |config|
  stale_vm_cleanup(config, "#{dev_user}-ubuntu", __dir__)

  config.vm.box              = box
  config.vm.box_check_update = false
  config.vm.hostname         = "#{dev_user}-ubuntu"

  # ── NAT port forwarding ────────────────────────────────────
  config.vm.network "forwarded_port", guest: 8080, host: 8080, id: "airflow"
  config.vm.network "forwarded_port", guest: 3210, host: 3210, host_ip: "0.0.0.0", id: "convex-local"
  config.vm.network "forwarded_port", guest: 3211, host: 3211, host_ip: "0.0.0.0", id: "convex-local-artifacts"
  config.vm.network "forwarded_port", guest: 3000, host: 3000, host_ip: "0.0.0.0", id: "convex-turborepo"
  config.vm.network "forwarded_port", guest: 2003, host: 2003, host_ip: "0.0.0.0", id: "graphql"
  config.vm.network "forwarded_port", guest: 3035, host: 3035, id: "sunrise-api"
  config.vm.network "forwarded_port", guest: 5173, host: 5173, host_ip: "0.0.0.0", id: "vite"
  config.vm.network "forwarded_port", guest: 5174, host: 5174, host_ip: "0.0.0.0", id: "vite2"

  # ── Shared folders ─────────────────────────────────────────
  config.vm.synced_folder VM_WORKSPACE, "/workspace",
    owner:         "vagrant",
    group:         "vagrant",
    mount_options: ["dmode=775", "fmode=664", "_netdev"]

  # ── VirtualBox provider ────────────────────────────────────
  config.vm.provider "virtualbox" do |vb|
    vb.name   = "#{dev_user}-ubuntu"
    vb.memory = VM_RAM_MB
    vb.cpus   = VM_CPUS
    vb.gui    = true

    vb.customize ["modifyvm", :id, "--vram",               "256"]
    vb.customize ["modifyvm", :id, "--graphicscontroller", "vmsvga"]
    vb.customize ["modifyvm", :id, "--accelerate3d",       "on"]
    vb.customize ["modifyvm", :id, "--clipboard",          "bidirectional"]
    vb.customize ["modifyvm", :id, "--draganddrop",        "bidirectional"]
    vb.customize ["modifyvm", :id, "--audio",              "default"]
    vb.customize ["modifyvm", :id, "--usb",                "on"]
    vb.customize ["modifyvm", :id, "--usbehci",            "on"]
    vb.customize ["modifyvm", :id, "--paravirtprovider",   "kvm"]
    vb.customize ["modifyvm", :id, "--x2apic",             "on"]
    vb.customize ["modifyvm", :id, "--largepages",         "on"]
  end

  standard_provisioners(config,
    profile_dir:  __dir__,
    dev_user:     dev_user,
    dev_password: dev_password,
    dev_tz:       dev_tz,
    tune_reboot:  true
  )

end
